# Application
APP_NAME="PO Approval System"
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://pouser:popassword@db:5432/poapproval
DATABASE_URL_SYNC=postgresql://pouser:popassword@db:5432/poapproval

# Redis (ARQ task queue)
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (Amazon SES or SMTP)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-user
SMTP_PASSWORD=your-ses-smtp-password
EMAIL_FROM=noreply@yourcompany.com
EMAIL_FROM_NAME="PO Approval System"

# File Storage (AWS S3 or MinIO)
S3_BUCKET=po-approval-docs
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# For local dev with MinIO:
# S3_ENDPOINT_URL=http://minio:9000

# First superuser (created on startup)
FIRST_SUPERUSER_EMAIL=admin@yourcompany.com
FIRST_SUPERUSER_PASSWORD=changeme123

# App URL (for email links)
APP_BASE_URL=http://localhost:8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
